{
  "name": "@foxglove/mcap-cli-conformance",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "lint:ci": "tsc -b && eslint --report-unused-disable-directives .",
    "run": "tsc -b && tsx src/index.ts",
    "run-tests": "tsc -b && tsx src/index.ts",
    "perf": "tsc -b && tsx src/perf.ts"
  },
  "dependencies": {
    "@mcap/core": "workspace:*",
    "@mcap/support": "workspace:*",
    "colors": "1.4.0",
    "commander": "11.1.0",
    "diff": "^5.1.0"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "1.0.1",
    "@foxglove/tsconfig": "3.2.0",
    "@types/diff": "^5.0.2",
    "@types/node": "20.19.33",
    "@typescript-eslint/eslint-plugin": "6.11.0",
    "@typescript-eslint/parser": "6.11.0",
    "eslint": "8.54.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-es": "4.1.0",
    "eslint-plugin-filenames": "1.3.2",
    "eslint-plugin-import": "2.29.0",
    "eslint-plugin-jest": "27.6.0",
    "eslint-plugin-prettier": "5.0.1",
    "prettier": "3.1.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
